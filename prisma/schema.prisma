generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String   @unique
  category    String
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([publishedAt(sort: Desc)])
}
